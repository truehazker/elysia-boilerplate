{
  "name": "elysia-boilerplate",
  "version": "0.6.0",
  "description": "A modern boilerplate for building APIs with Elysia, Bun runtime, and PostgreSQL.",
  "author": "Truehazker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/truehazker/elysia-boilerplate"
  },
  "homepage": "https://github.com/truehazker/elysia-boilerplate",
  "bugs": "https://github.com/truehazker/elysia-boilerplate/issues",
  "scripts": {
    "start": "bun run src/cli.ts serve",
    "dev": "bun run --watch src/cli.ts serve",
    "build": "bun build --compile --minify-whitespace --minify-syntax --outfile build/server src/cli.ts",
    "db:generate": "bun run --bun drizzle-kit generate",
    "db:migrate": "bun run src/cli.ts migrate",
    "db:studio": "bun run --bun drizzle-kit studio",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test ./tests/unit",
    "test:int": "bun test --preload ./tests/support/setup.ts ./tests/int",
    "test:e2e": "bun test --preload ./tests/support/setup.ts ./tests/e2e"
  },
  "main": "src/cli.ts",
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@elysia/opentelemetry": "1.4.12",
    "@opentelemetry/exporter-trace-otlp-proto": "0.200.0",
    "@opentelemetry/resources": "2.0.0",
    "@opentelemetry/sdk-trace-node": "2.0.0",
    "commander": "^15.0.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.28",
    "envalid": "^8.1.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.3"
  }
}
