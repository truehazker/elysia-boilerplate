# Application Environment
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=debug

# Server Configuration
SERVER_HOSTNAME=localhost
SERVER_PORT=3000

# Database Configuration
# Replace with your actual PostgreSQL connection details
DATABASE_DSN=postgresql://postgres:postgres@localhost:5432/elysia-boilerplate

# Maximum number of connections in the DB pool. Tune per-deployment based
# on Postgres max_connections and the number of replicas of this service.
DB_POOL_MAX=10

# Seconds to wait for a connection to be established before failing.
DB_POOL_CONNECTION_TIMEOUT=5

# Seconds an idle connection is kept in the pool before being closed.
DB_POOL_IDLE_TIMEOUT=30

# Enable migrations on server startup
DB_AUTO_MIGRATE=false

# Enable OpenAPI documentation to be available on /openapi route
ENABLE_OPENAPI=true
