# Defaults for `bun test`. Bun auto-sets NODE_ENV=test, which auto-loads
# this file. Values here are placeholders that satisfy the envalid checks
# in src/common/config.ts; unit tests must NOT actually connect.
#
# Integration tests override DATABASE_DSN in tests/int/setup.ts after
# booting a Postgres testcontainer, so the placeholder below is harmless.

NODE_ENV=test
LOG_LEVEL=silent
DATABASE_DSN=postgresql://placeholder:placeholder@127.0.0.1:5432/placeholder
DB_POOL_MAX=5
DB_POOL_CONNECTION_TIMEOUT=2
DB_POOL_IDLE_TIMEOUT=5
DB_AUTO_MIGRATE=false
ENABLE_OPENAPI=false
